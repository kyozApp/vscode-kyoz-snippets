{
  "SvelteKit: +page.svelte (Runes)": {
    "prefix": "svelte-page",
    "body": [
      "<script lang=\"ts\">",
      "  let { data } = \\$props();",
      "</script>",
      "",
      "<svelte:head>",
      "  <title>${1:Título} | AduShared</title>",
      "</svelte:head>",
      "",
      "<main>",
      "  <h1>${1:Título}</h1>",
      "  $0",
      "</main>",
      "",
      "<style>",
      "</style>"
    ],
    "description": "Template de Svelte 5 con Runes para archivos +page.svelte"
  },

  "SvelteKit: +page.svelte (Superform)": {
    "prefix": "svelte-page-form",
    "body": [
      "<script lang=\"ts\">",
      "  import { superForm } from 'sveltekit-superforms';",
      "",
      "  let { data } = \\$props();",
      "",
      "  const { form, errors, enhance, delayed } = superForm(data.form);",
      "</script>",
      "",
      "<svelte:head>",
      "  <title>${1:Form Page} | AduShared</title>",
      "</svelte:head>",
      "",
      "<div>",
      "  <header>",
      "    <h1>${1:Form Page}</h1>",
      "  </header>",
      "",
      "  <form method=\"POST\" use:enhance>",
      "    $0",
      "    <button type=\"submit\" disabled={\\$delayed}>",
      "      {#if \\$delayed}Cargando...{:else}Guardar{/if}",
      "    </button>",
      "  </form>",
      "</div>",
      "",
      "<style>",
      "</style>"
    ],
    "description": "Template de Svelte 5 con Superform integrado"
  },

  "SvelteKit: +layout.svelte": {
    "prefix": "svelte-layout",
    "body": [
      "<script lang=\"ts\">",
      "  let { children } = \\$props();",
      "</script>",
      "",
      "<div>",
      "  {@render children()}",
      "</div>",
      "",
      "<style>",
      "</style>"
    ],
    "description": "Template de Svelte 5 para archivos +layout.svelte"
  },

  "SvelteKit: +page.server.ts": {
