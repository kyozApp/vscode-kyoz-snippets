  "Hono: Zod Validator": {
    "prefix": "hono-zod",
    "body": [
      "import { z } from 'zod';",
      "import { zValidator } from '@hono/zod-validator';",
      "",
      "const ${1:schema} = z.object({",
      "  ${2:name}: z.string(),",
      "});",
      "",
      "${3:router}.${4:post}('/${5:route}', zValidator('${6:json}', ${1:schema}), (c) => {",
      "  const data = c.req.valid('${6:json}');",
      "  return c.json({",
      "    success: true,",
      "    message: 'Validación exitosa',",
      "    code: 'VALIDATION_SUCCESS',",
      "    statusCode: 200,",
