{
  "Hono: Index Server (AduShared Style)": {
    "prefix": "hono-index",
    "body": [
      "/**",
      " * 📁 **File**: index.ts",
      " * @description Punto de entrada principal para el servidor Hono.",
      " * @module root",
      " * @version 1.0.0",
      " */",
      "",
      "process.env.TZ = 'UTC';",
      "import { serve } from '@hono/node-server';",
      "import { Hono } from 'hono';",
      "import { env } from './core/env.js';",
      "import { logger } from './core/logger.js';",
      "",
      "const app = new Hono();",
      "",
      "/**",
      " * 🚀 **Section: Healthcheck**",
      " */",
      "app.get('/health', (c) =>",
      "  c.json({",
      "    success: true,",
      "    message: 'API is online',",
      "    code: 'SERVICE_HEALTH_OK',",
      "    statusCode: 200,",
      "    data: {",
      "      environment: env.SERVER_ENV,",
      "      status: 'online'",
      "    },",
      "    error: null",
      "  })",
      ");",
      "",
      "/**",
      " * ⚙️ **Section: Server Initialization**",
      " */",
      "const server = serve(",
      "  {",
      "    fetch: app.fetch,",
      "    port: env.SERVER_PORT,",
      "  },",
      "  (info) => {",
      "    console.log(`[RUNNING] Server on: http://localhost:\\${info.port}`);",
      "  }",
      ");",
      "",
      "/**",
      " * 🛑 **Section: Graceful Shutdown**",
      " */",
      "const shutdown = async (signal: string) => {",
      "  console.log(`\\n🛑 Received \\${signal}. Closing server resources...`);",
      "  try {",
      "    server.close();",
      "    console.log('✅ Server closed.');",
      "    process.exit(0);",
      "  } catch (error) {",
      "    console.error('❌ Error during shutdown:', error);",
      "    process.exit(1);",
      "  }",
      "};",
      "",
      "process.on('SIGTERM', () => shutdown('SIGTERM'));",
      "process.on('SIGINT', () => shutdown('SIGINT'));"
    ],
    "description": "Bootstrap profesional para Hono v4 con Graceful Shutdown y Healthcheck"
  },

  "Hono: Env Config (AduShared Style)": {
    "prefix": "hono-env",
    "body": [
      "/**",
      " * 📁 **File**: env.ts",
      " * @description Validación y tipado estricto para las variables de entorno.",
      " * @module core",
      " * @version 1.0.0",
      " */",
      "",
      "import type { Context } from 'hono';",
      "import { env as honoEnv } from 'hono/adapter';",
      "import { z } from 'zod';",
      "",
      "/**",
      " * 🧬 **Schema: envSchema**",
      " */",
      "export const envSchema = z.object({",
      "  SERVER_ENV: z.enum(['development', 'production', 'test']).default('development'),",
      "  SERVER_PORT: z.coerce.number().int().positive().default(${1:3000}),",
      "  DATABASE_URL: z.string().url({ error: 'DATABASE_URL inválida' }),",
      "  JWT_SECRET: z.string().min(32).optional(),",
      "});",
      "",
      "/**",
      " * @description Obtiene variables de entorno validadas dentro de Hono.",
      " */",
      "export const getSafeEnv = (c: Context) => {",
      "  const result = envSchema.safeParse(honoEnv(c));",
      "  if (!result.success) {",
      "    throw new Error('Configuración de Entorno Inválida');",
      "  }",
      "  return result.data;",
      "};",
      "",
      "/**",
      " * Singleton para uso fuera de Hono (Prisma, etc.)",
      " */",
      "const parsedEnv = envSchema.safeParse(process.env);",
      "",
      "if (!parsedEnv.success) {",
      "  console.error('❌ Variables de entorno faltantes:', parsedEnv.error.format());",
      "  process.exit(1);",
      "}",
      "",
      "export const env = parsedEnv.data;"
    ],
    "description": "Configuración de entorno profesional con Zod y Singleton"
  },

  "Hono: Router Básico": {
    "prefix": "hono-router",
    "body": [
      "/**",
      " * 📁 **File**: ${TM_FILENAME}",
      " * @description Router básico para el módulo ${1:${TM_FILENAME_BASE}}",
      " * @module modules/${1:${TM_FILENAME_BASE}}",
      " * @version 1.0.0",
      " */",
      "",
      "import { Hono } from 'hono';",
      "",
      "const ${1:router} = new Hono();",
      "",
      "${1:router}.get('/', (c) => {",
      "  return c.json({",
      "    success: true,",
      "    message: 'Success',",
      "    code: 'OK',",
      "    statusCode: 200,",
      "    data: {},",
      "    error: null",
      "  });",
      "});",
      "",
      "export default ${1:router};"
    ]
  },

  "Hono: CRUD Completo": {
    "prefix": "hono-crud",
    "body": [
      "/**",
      " * 📁 **File**: ${TM_FILENAME}",
      " * @description CRUD completo para el módulo ${1:${TM_FILENAME_BASE}}",
      " * @module modules/${1:${TM_FILENAME_BASE}}",
      " * @version 1.0.0",
      " */",
      "",
      "import { Hono } from 'hono';",
      "",
      "const ${1:router} = new Hono();",
      "",
      "// 🟢 Listar todos",
      "${1:router}.get('/', async (c) => {",
      "  return c.json({",
      "    success: true,",
      "    message: 'Registros obtenidos',",
      "    code: 'FETCH_SUCCESS',",
      "    statusCode: 200,",
      "    data: [],",
      "    error: null",
      "  });",
      "});",
      "",
      "// 🔵 Obtener por ID",
      "${1:router}.get('/:id', async (c) => {",
      "  const id = c.req.param('id');",
      "  return c.json({",
      "    success: true,",
      "    message: 'Registro encontrado',",
      "    code: 'GET_SUCCESS',",
      "    statusCode: 200,",
      "    data: { id },",
      "    error: null",
      "  });",
      "});",
      "",
      "// 🟠 Crear",
      "${1:router}.post('/', async (c) => {",
      "  const body = await c.req.json();",
      "  return c.json({",
      "    success: true,",
      "    message: 'Registro creado',",
      "    code: 'CREATE_SUCCESS',",
      "    statusCode: 201,",
      "    data: body,",
      "    error: null",
      "  }, 201);",
      "});",
      "",
      "// 🟡 Actualizar",
      "${1:router}.patch('/:id', async (c) => {",
      "  const id = c.req.param('id');",
      "  const body = await c.req.json();",
      "  return c.json({",
      "    success: true,",
      "    message: 'Registro actualizado',",
      "    code: 'UPDATE_SUCCESS',",
      "    statusCode: 200,",
      "    data: { id, ...body },",
      "    error: null",
      "  });",
      "});",
      "",
      "// 🔴 Eliminar",
      "${1:router}.delete('/:id', async (c) => {",
      "  const id = c.req.param('id');",
      "  return c.json({",
      "    success: true,",
      "    message: 'Registro eliminado',",
      "    code: 'DELETE_SUCCESS',",
      "    statusCode: 200,",
      "    data: { id },",
      "    error: null",
      "  });",
      "});",
      "",
      "export default ${1:router};"
    ]
  },

