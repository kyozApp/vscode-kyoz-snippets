{
  "Página Astro con props": {
    "prefix": "astro-page",
    "body": [
      "---",
      "/**",
      " * 📁 **File**: ${TM_FILENAME}",
      " * @description ${1:Página de Astro.}",
      " * @module pages",
      " * @version 1.0.0",
      " */",
      "",
      "export interface Props {",
      "  title: string;",
      "}",
      "",
      "const { title } = Astro.props;",
      "---",
      "",
      "<html lang=\"es\">",
      "  <head>",
      "    <meta charset=\"utf-8\" />",
      "    <title>{title}</title>",
      "  </head>",
      "  <body>",
      "    <h1>{title}</h1>",
      "    <slot />$0",
      "  </body>",
      "</html>"
    ],
    "description": "Plantilla de página Astro con TypeScript"
  }
}