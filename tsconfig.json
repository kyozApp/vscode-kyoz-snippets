{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2024",
    "lib": ["ES2024"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out"
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test"]
}
